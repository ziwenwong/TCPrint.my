{
  "name": "nutrivo-outro",
  "version": "1.0.0",
  "description": "My Remotion video",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.485",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.485",
    "@remotion/tailwind-v4": "4.0.485",
    "tailwindcss": "4.0.0"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.485",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "render": "remotion render src/index.ts NutrivoOutro ../outputs/nutrivo-outro/nutrivo-outro.mp4 --codec=h264 --pixel-format=yuv420p",
    "render:fallback": "python3 scripts/render-fallback.py",
    "render:water": "python3 scripts/render-water.py",
    "still": "remotion still src/index.ts NutrivoOutro ../outputs/nutrivo-outro/preview.png --frame=45",
    "still:water": "remotion still src/index.ts NutrivoWaterOutro ../outputs/nutrivo-outro/preview-water.png --frame=45",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc"
  },
  "sideEffects": [
    "*.css"
  ]
}
